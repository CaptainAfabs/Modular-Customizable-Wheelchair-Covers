# Treat binary CAD/print/media files as binary so git doesn't try to diff them
*.stl       binary
*.f3d       binary
*.f3z       binary
*.step      binary
*.stp       binary
*.iges      binary
*.igs       binary
*.3mf       binary
*.gcode     binary
*.pdf       binary
*.docx      binary
*.xlsx      binary
*.pptx      binary
*.jpg       binary
*.jpeg      binary
*.png       binary
*.gif       binary
*.mov       binary
*.mp4       binary
*.webm      binary

# Normalize text files to LF on commit
*.md          text eol=lf
*.txt         text eol=lf
LICENSE       text eol=lf
NOTICE        text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf

# Mark generated / source-of-truth files so GitHub language stats are accurate
docs/**             linguist-documentation
hardware/drawings/** linguist-vendored
images/**           linguist-vendored
